# Plantilla de variables de entorno.
# Copiá este archivo como ".env" (ver README → "Cómo comenzar").

# URL base de la API (backend Express + Supabase).
# - Para probar en la web del PC: dejar http://localhost:3000
# - En un celular físico: usar la IP de tu PC en la red (ej. http://192.168.1.50:3000)
# - En emulador de Android: http://10.0.2.2:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Capa "mock" de autenticación para probar SIN backend (true | false).
# QA / sin backend levantado: dejar en "true" → login y registro funcionan con datos de prueba.
# Desarrollo contra el backend real: poner en "false".
EXPO_PUBLIC_USE_MOCK_AUTH=true
